<?xml version="1.0" encoding="UTF-8"?>
<!--
  Configuracion de despliegue para WildFly 39 con Spring Boot 3.5 WAR.

  IMPORTANTE sobre lo que NO se excluye:
  - subsystem "jpa": WildFly no crea un PersistenceUnit propio para WARs
    sin persistence.xml. Spring Boot gestiona JPA sin conflicto.
  - subsystem "bean-validation": excluirlo rompe la jerarquia de classloaders
    que Weld usa para cargar ValidationExtension de Hibernate Validator,
    provocando un LinkageError en POST_MODULE. Sin esta exclusion, Weld
    resuelve la extension usando el classloader de WildFly de forma consistente.
  - module "org.hibernate.validator": idem anterior; excluirlo provoca que
    el WAR cargue sus clases HV desde WEB-INF/lib mientras la extension CDI
    sigue usando el modulo del servidor, causando el mismo LinkageError.

  Lo que SI se excluye:
  - subsystem "logging": Spring Boot usa Logback propio; sin esto los logs
    aparecen duplicados y con formato incorrecto.
  - subsystem "jaxrs": Spring MVC maneja REST; el subsistema JAX-RS de
    WildFly intentaria registrar sus propios recursos.
  - subsystem "webservices": no se usa JAX-WS.
  - Modulos de SLF4J/Log4j del servidor: para que Logback use sus propios
    jars embebidos en WEB-INF/lib.
-->
<jboss-deployment-structure xmlns="urn:jboss:deployment-structure:1.3">
    <deployment>
        <exclude-subsystems>
            <subsystem name="logging"/>
            <subsystem name="jaxrs"/>
            <subsystem name="webservices"/>
        </exclude-subsystems>
        <exclusions>
            <module name="org.apache.log4j"/>
            <module name="org.apache.logging.log4j.api"/>
            <module name="org.slf4j"/>
            <module name="org.slf4j.impl"/>
            <module name="org.jboss.logging.jul-to-slf4j-stub"/>
        </exclusions>
    </deployment>
</jboss-deployment-structure>
